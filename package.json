{
  "name": "learning-space-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently -n server,web -c blue,green \"cross-env PORT=3000 node server/index.js\" \"npm --prefix web run dev\"",
    "build": "npm --prefix web run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.4.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
